{
  "dashboard": {
    "title": "Business Metrics Dashboard",
    "tags": ["business", "analytics"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Total Users",
        "targets": [
          {
            "expr": "alunos_total_users"
          }
        ],
        "type": "stat"
      },
      {
        "id": 2,
        "title": "Active Users (24h)",
        "targets": [
          {
            "expr": "alunos_active_users_24h"
          }
        ],
        "type": "stat"
      },
      {
        "id": 3,
        "title": "Course Enrollments",
        "targets": [
          {
            "expr": "conteudos_course_enrollments"
          }
        ],
        "type": "stat"
      },
      {
        "id": 4,
        "title": "Average Course Completion %",
        "targets": [
          {
            "expr": "avg(conteudos_course_completion_percentage)"
          }
        ],
        "type": "gauge"
      },
      {
        "id": 5,
        "title": "Total Revenue",
        "targets": [
          {
            "expr": "pagamentos_total_revenue_brl"
          }
        ],
        "type": "stat"
      },
      {
        "id": 6,
        "title": "Payment Success Rate",
        "targets": [
          {
            "expr": "pagamentos_success_rate * 100"
          }
        ],
        "type": "gauge"
      },
      {
        "id": 7,
        "title": "Revenue Trend (7d)",
        "targets": [
          {
            "expr": "increase(pagamentos_total_revenue_brl[1d])"
          }
        ],
        "type": "graph"
      },
      {
        "id": 8,
        "title": "Failed Payments",
        "targets": [
          {
            "expr": "rate(pagamentos_failures_total[1h])"
          }
        ],
        "type": "graph"
      }
    ],
    "schemaVersion": 27,
    "version": 1
  }
}
